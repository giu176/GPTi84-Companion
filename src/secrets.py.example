# Copy to secrets.py (gitignored) and fill in. Loaded by src/net.py at
# bridge startup on the Pico W.

# --- Wifi ----------------------------------------------------------------

WIFI_SSID = ""
WIFI_PASSWORD = ""

# --- Transport selection -------------------------------------------------
#
# True  : route the calc <-> desktop bridge through a WebSocket-over-TLS
#         endpoint. Use this if your relay is behind Cloudflare Tunnel +
#         Cloudflare Access (the shipped configuration).
# False : raw TCP. Use this for LAN dev (e.g. running tools/relay_server.py
#         on a workstation) or any environment where you don't want to
#         stand up a public hostname.

SERVER_WSS = False

# --- Raw TCP path (SERVER_WSS = False) -----------------------------------

SERVER_HOST = "192.168.1.10"   # IP / hostname of the machine running tools/relay_server.py
SERVER_PORT = 9999

# --- WSS path (SERVER_WSS = True) ----------------------------------------
#
# The Pico opens wss://<SERVER_HOST>:<SERVER_PORT><WS_PATH> and presents
# the CF-Access-Client-Id / CF-Access-Client-Secret headers issued by
# your Cloudflare Access service token. See README.md for the relay
# stand-up walkthrough.

# SERVER_HOST = "relay.example.com"
# SERVER_PORT = 443
# WS_PATH = "/ws"
# CF_ACCESS_CLIENT_ID = ""
# CF_ACCESS_CLIENT_SECRET = ""
