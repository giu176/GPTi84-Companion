; CHAT.z80: chat-UI stub. Reads keys via _GetKey (which on the 84+ returns
; resolved kKey codes, including alpha-shifted letters), accumulates a
; line on row 7, redraws on every keystroke. [DEL] backspaces, [ENTER]
; clears the line (DBUS send goes here next), [CLEAR] exits.
;
; Build:  just asm  programs/asm_chat/CHAT.z80
; Push:   just push-asm programs/asm_chat/CHAT.z80

.nolist
#include "ti83plus.inc"
.list

.org    $9D93
.db     t2ByteTok, tAsmCmp

BUFMAX  .equ    64

        bcall(_ClrLCDFull)
        ld      hl, 0
        ld      (curRow), hl
        ld      hl, banner
        bcall(_PutS)
        bcall(_NewLine)

        xor     a
        ld      (buflen), a
        ld      hl, buf
        ld      (hl), 0

input_loop:
        bcall(_GetKey)
        cp      kClear
        jp      z, done
        cp      kEnter
        jr      z, on_enter
        cp      kDel
        jr      z, on_del

        call    key_to_ascii
        or      a
        jr      z, input_loop

        ld      b, a
        ld      a, (buflen)
        cp      BUFMAX
        jr      nc, input_loop
        ld      hl, buf
        ld      e, a
        ld      d, 0
        add     hl, de
        ld      (hl), b
        inc     a
        ld      (buflen), a
        inc     hl
        ld      (hl), 0
        call    redraw_line
        jr      input_loop

on_del:
        ld      a, (buflen)
        or      a
        jr      z, input_loop
        dec     a
        ld      (buflen), a
        ld      hl, buf
        ld      e, a
        ld      d, 0
        add     hl, de
        ld      (hl), 0
        call    redraw_line
        jr      input_loop

on_enter:
        ld      a, (buflen)
        or      a
        jr      z, _enter_clear     ; empty line: just clear, no send

        ; Build OP1 = [AppVarObj, 'C','H','A','T','M','S','G', 0]
        ld      hl, op1_appvar_name
        rst     rMOV9TOOP1

        ; If CHATMSG already exists, delete so _CreateAppVar gets a clean
        ; slot. _ChkFindSym: cf=0 if found, cf=1 if not.
        bcall(_ChkFindSym)
        jr      c, _enter_create
        bcall(_DelVarArc)

_enter_create:
        ; OP1 may have been clobbered by lookup/delete; reload.
        ld      hl, op1_appvar_name
        rst     rMOV9TOOP1
        ld      a, (buflen)
        ld      l, a
        ld      h, 0
        bcall(_CreateAppVar)        ; HL=size; out: DE -> [size_lo,size_hi,data]
        jr      c, _enter_err

        ; Copy (buf, buflen) into the var's data area, past the 2-byte size word.
        inc     de
        inc     de
        ld      hl, buf
        ld      a, (buflen)
        ld      c, a
        ld      b, 0
        ldir

        ; Reload OP1 (silent send may have clobbered it during lookup).
        ld      hl, op1_appvar_name
        rst     rMOV9TOOP1
        bcall(_SendVarCmd)
        jr      c, _enter_err
        jr      _enter_clear

_enter_err:
        ; Mark failure with an "X" at row 0, col 15.
        ld      hl, $0F00            ; curRow=0 (L), curCol=15 (H)
        ld      (curRow), hl
        ld      a, 'X'
        bcall(_PutC)

_enter_clear:
        xor     a
        ld      (buflen), a
        ld      hl, buf
        ld      (hl), 0
        call    redraw_line
        jp      input_loop

done:
        bcall(_ClrLCDFull)
        ret

; Redraw the input line at row 7.
redraw_line:
        ld      hl, $0007        ; curRow=7, curCol=0 (curRow=L, curCol=H)
        ld      (curRow), hl
        bcall(_EraseEOL)
        ld      hl, buf
        bcall(_PutS)
        ret

; key_to_ascii: A in = kKey* code (post-alpha resolution by _GetKey),
; A out = ASCII char or 0 if unmapped.
;
; kCapA..kCapZ are contiguous (0x9A..0xB3), so we range-check and
; subtract. Digits and punctuation come through a small lookup table.
key_to_ascii:
        ; Letters first: kCapA (0x9A) <= A <= kCapZ (0xB3) -> 'A'..'Z'.
        cp      kCapA
        jr      c, _ka_table
        cp      kCapZ + 1
        jr      nc, _ka_table
        sub     kCapA
        add     a, 'A'
        ret

_ka_table:
        ld      c, a
        ld      hl, key_table
_kt_next:
        ld      a, (hl)
        or      a
        ret     z
        cp      c
        jr      z, _kt_hit
        inc     hl
        inc     hl
        jr      _kt_next
_kt_hit:
        inc     hl
        ld      a, (hl)
        ret

key_table:
        .db     k0,       '0'
        .db     k1,       '1'
        .db     k2,       '2'
        .db     k3,       '3'
        .db     k4,       '4'
        .db     k5,       '5'
        .db     k6,       '6'
        .db     k7,       '7'
        .db     k8,       '8'
        .db     k9,       '9'
        .db     kDecPnt,  '.'
        .db     kAdd,     '+'
        .db     kSub,     '-'
        .db     kMul,     '*'
        .db     kDiv,     '/'
        .db     kLParen,  '('
        .db     kRParen,  ')'
        .db     kComma,   ','
        .db     kSpace,   ' '
        .db     0

banner: .db     "asm_chat", 0
op1_appvar_name:
        .db     AppVarObj, "CHATMSG", 0
buf:    .db     0
        .fill   BUFMAX, 0
buflen: .db     0

.end
