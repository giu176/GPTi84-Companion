; CHAT.z80: ship Str1 to the Pico/desktop and exit. Reply lands in Str2.
;
; Architecture (post-2026-04-28 pivot to native String vars):
;   At the home screen, user prepares input with `"text"->Str1` (or any
;   expression -- numbers, math notation, all stored as a token stream
;   inside the String var). User runs `Asm(prgmCHAT)`. We look up Str1
;   in NVRAM, ship it via _SendVarCmd, and exit.
;
;   The Pico relays the token stream to the desktop, which translates
;   tokens to ASCII, processes the message, translates the reply back
;   to tokens, and PC-master pushes it to the calc as Str2. Calc must
;   be at the home screen for the OS's idle silent-link receive to
;   accept it; we exit cleanly so that condition is satisfied.
;
;   User invokes `Str2 ENTER` at the home screen to see the reply.
;
; Why no on-calc UI: the calc already has a string editor. Building
;   another one in asm was 200 lines of mistakes. Calc-native input is
;   also structured (token stream), enabling a future math-notation
;   pipeline desktop-side.
;
; Build:  just asm  programs/asm_chat/CHAT.z80
; Push:   just push-asm programs/asm_chat/CHAT.z80

.nolist
#include "ti83plus.inc"
.list

.org    $9D93
.db     t2ByteTok, tAsmCmp


start:
        ld      hl, op1_str1
        rst     rMOV9TOOP1
        bcall(_ChkFindSym)
        ret     c                       ; Str1 not defined; bail silently

        ; _SendVarCmd reads the variable named by OP1. _ChkFindSym may
        ; have left OP1 alone but reload to be defensive: silent-link
        ; bcalls are documented to clobber OP-area scratch.
        ld      hl, op1_str1
        rst     rMOV9TOOP1
        bcall(_SendVarCmd)
        ret

op1_str1:
        .db     StrngObj, tVarStrng, tStr1, 0, 0, 0, 0, 0, 0

.end
