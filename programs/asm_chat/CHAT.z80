; CHAT.z80: ship Str1 (V2 command/prompt) to the Pico/phone and exit.
; Reply lands in Str3..Str0 plus real N.
;
; A TI-BASIC deck owns the GUI. It writes one command frame to Str1,
; calls Asm(prgmCHAT), then renders the pages the Pico pushes back.
; The asm stays dumb: send Str1, exit.
;
; Command examples:
;   LIST
;   OPEN C1234...
;   SEND C1234... M1
;   hello from the calculator
;
; Build:  just asm  programs/asm_chat/CHAT.z80
; Push:   just push-asm programs/asm_chat/CHAT.z80

.nolist
#include "ti83plus.inc"
.list

.org    $9D93
.db     t2ByteTok, tAsmCmp


start:
        ld      hl, op1_str1
        rst     rMOV9TOOP1
        bcall(_ChkFindSym)
        ret     c                       ; Str1 missing; done

        ld      hl, op1_str1
        rst     rMOV9TOOP1
        bcall(_SendVarCmd)
        ret

op1_str1:
        .db     StrngObj, tVarStrng, tStr1, 0, 0, 0, 0, 0, 0

.end
